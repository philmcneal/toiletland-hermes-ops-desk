# Phase 5 live READ-ONLY connector config — EXAMPLE ONLY (no real secrets here).
#
# Copy this to  .secrets/live-readonly.env  and fill in real values there.
# .secrets/ and *.env are git-ignored, so the real file is never committed.
#
#     mkdir -p .secrets
#     cp live-readonly.env.example .secrets/live-readonly.env
#     # edit .secrets/live-readonly.env with real credentials
#
# Nothing here is ever printed by the tooling: live_ingest --status and
# /api/live/status expose presence/hints only, never values.
#
# Read-only means read-only: no email send/mark/move/delete, no WooCommerce
# edits/refunds, no Stripe charges/links/refunds. Mutations stay disabled.

# ---- Master gate. Must be true for ANY live fetch (dry-run or --write). ----
LIVE_READONLY_ENABLED=false

# ---- Email (IMAP, read-only EXAMINE + BODY.PEEK) ----
# For Gmail/Workspace use an App Password (not your login password) and IMAP on.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=ops@example.com
IMAP_PASSWORD=REPLACE_WITH_APP_PASSWORD
IMAP_MAILBOX=INBOX
IMAP_ENABLED=false

# ---- WooCommerce (read-only GET /wp-json/wc/v3/orders) ----
# Create a READ-ONLY REST API key in WooCommerce > Settings > Advanced > REST API.
WOO_BASE_URL=https://store.example.com
WOO_CONSUMER_KEY=ck_REPLACE_ME
WOO_CONSUMER_SECRET=cs_REPLACE_ME
WOO_ENABLED=false

# ---- Stripe (TEST-MODE status proof only) ----
# Only an sk_test_ key is ever accepted. A live key is refused. No API call.
STRIPE_TEST_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_ENABLED=false
