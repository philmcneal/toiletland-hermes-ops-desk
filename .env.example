# Toiletland × Hermes SMB Operator — local backend config (EXAMPLE ONLY)
# Copy to .env for local use. NEVER commit a real .env (see .gitignore).
# Phase 0 + Phase 1 are fixture-only. No real credentials belong in this file.

# ---- Mode switches (Phase 0) ----
# Fixture mode serves the existing redacted JSON fixtures from SQLite.
DEMO_FIXTURE_MODE=true
# Reserved for a future phase. Keep false: no dry-run connectors are wired yet.
LIVE_DRY_RUN_MODE=false
# Master kill switch for every live connector. Phase 0/1 keep this OFF.
LIVE_CONNECTORS=off

# ---- Local backend (Phase 1, Python stdlib http.server + SQLite) ----
OPS_DESK_HOST=127.0.0.1
OPS_DESK_PORT=8770
# SQLite file lives next to the backend; it is gitignored.
OPS_DESK_DB=control-room-demo/backend/ops_desk.db
# Directory of the canonical redacted fixtures used to seed SQLite.
OPS_DESK_DATA_DIR=control-room-demo/data

# ---- Credentials (INTENTIONALLY BLANK) ----
# No connector reads these yet. They exist only to document the future shape.
# Leave blank. A live phase would require explicit owner approval first.
STRIPE_SECRET_KEY=
GOOGLE_ADS_DEVELOPER_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
WOOCOMMERCE_CONSUMER_KEY=
